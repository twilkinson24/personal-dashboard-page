# Finnhub API key — set this in Cloudflare Pages:
#   Pages project → Settings → Environment Variables → Production
#
# Get a free key at https://finnhub.io/
FINNHUB_API_KEY=your_finnhub_api_key_here

# Dashboard password — protects the site with HTTP Basic Auth.
# Set this in Cloudflare Pages → Settings → Environment Variables → Production.
# If left unset, the site will be publicly accessible.
DASHBOARD_PASSWORD=your_password_here
